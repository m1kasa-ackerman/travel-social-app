# ============================================================
# WANDRLY BACKEND — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Supabase Database (use PgBouncer port 6543, NOT 5432) ---
SUPABASE_HOST=db.xxxxxxxxxxxx.supabase.co
SUPABASE_USERNAME=postgres
SUPABASE_PASSWORD=your_supabase_db_password_here

# --- JWT (generate with: openssl rand -base64 64) ---
JWT_SECRET=replace_with_64_byte_base64_secret

# --- CORS (your frontend URL) ---
FRONTEND_URL=http://localhost:5173

# ============================================================
# For Railway deployment, set all of the above in the
# Railway dashboard under "Variables". Do NOT ship this file.
# ============================================================
